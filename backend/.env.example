# Backend environment variables — copy to .env and adjust as needed

# Main application database
DATABASE_URL=postgres://app:app@localhost:5434/app

# Test database (used by integration tests)
TEST_DATABASE_URL=postgres://app:app@localhost:5434/app_test

# HTTP server port
PORT=3000

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Comma-separated browser origins allowed to call the API (required when UI is hosted elsewhere)
# CORS_ORIGIN=http://localhost:8080,https://your-app.onrender.com

# Optional in production — only required for running tests locally
# TEST_DATABASE_URL=postgres://app:app@localhost:5434/app_test
